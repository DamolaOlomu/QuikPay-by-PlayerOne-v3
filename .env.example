# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=PlayerOnePay
APP_ENV=development          # development | staging | production
APP_VERSION=2.0.0
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── API ────────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database ───────────────────────────────────────────────────────────────────
# Production: postgresql+asyncpg://postgres:yourpassword@localhost:5432/quikpay
# Development: postgresql+asyncpg://postgres:yourpassword@localhost:5432/quikpay

DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/quikpay
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ───────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_32_char_fernet_key_here
BCRYPT_ROUNDS=12

# ── Redis (Rate Limiting & Cache) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Sentry (Error Tracking) ────────────────────────────────────────────────────
SENTRY_DSN=                  # Leave blank to disable

# ── Webhooks ───────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=CHANGE_ME_webhook_signing_secret
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_SECONDS=10

# ── Payment Processor ──────────────────────────────────────────────────────────
PAYMENT_PROCESSOR_API_KEY=
PAYMENT_PROCESSOR_BASE_URL=https://api.paymentprocessor.example.com

# Glyde sandbox integration
GLYDE_ENABLED=false
GLYDE_ENV=sandbox
GLYDE_BASE_URL=https://sandbox.useglyde.co/v1
GLYDE_SECRET_KEY=sk_sandbox_your_secret_key
GLYDE_WEBHOOK_SIGNING_KEY=

# ── Provider selection ────────────────────────────────────────────────────────
# "mock" (default, no external deps) | "glyde" | future: "monnify" | "paystack"
PAYMENT_PROVIDER=mock

# Mock bank — point this at your local webhook endpoint to test the full flow
# e.g. http://localhost:8000/api/v1/webhooks/mock-bank
MOCK_BANK_WEBHOOK_URL=
MOCK_BANK_DISPATCHER_INTERVAL_SECONDS=5
